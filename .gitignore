.artifacts/*
!.artifacts/.gitkeep
.worktrees/
.playwright-mcp/
docs/initial_pormpt.md
docs/initial_pormpt.pdf

*.log
*.tmp
*.bak
Thumbs.db
Desktop.ini

/.external-resource

# Build output of scripts/build-portable-plugin.ps1 (Target 1 publishability).
# This is generated, not source — ignore it from the dev tree. Release branches
# may carry a single materialized copy if a portable release is being staged.
/dist/

# .opencode/ holds dev memory + acceptance artifacts + legacy skill stash;
# ship only the OpenCode plugin code and the user-facing INSTALL.md.
/.opencode/*
!/.opencode/plugins/
!/.opencode/INSTALL.md

# Dev-internal router (per AGENTS.md policy)
AGENTS.md

# xedit-hook-bridge: ship the DLL from dist/ only. The .pas source lives in
# the sister xEdit fork (D:\TES5Edit-contrib), and Delphi build leftovers
# (.dcu / .dproj.local / .identcache / .res) are dev-only artifacts.
/tools/xedit-hook-bridge/src/
/tools/xedit-hook-bridge/*.dcu
/tools/xedit-hook-bridge/*.dproj.local
/tools/xedit-hook-bridge/*.identcache
/tools/xedit-hook-bridge/*.res

# /plugins/<name>/ is the materialized end-user marketplace tree required by
# Codex's marketplace schema (see .agents/plugins/marketplace.json). It is
# regenerated from source via scripts/build-portable-plugin.ps1 on every
# release. Tracked, not ignored. The sibling marketplace.json that the build
# script writes at /plugins/marketplace.json (portable-distribution shape) is
# NOT our canonical marketplace manifest and stays ignored.
/plugins/marketplace.json

# BGS KB pack build artifact; source records + manifest.json are committed.
/knowledge/bgs-kb/packs/*/kb.sqlite
*.pyc

# Python package build artifacts for the standalone bgs-translator PyPI package.
/tools/bgs-translator/build/
/tools/bgs-translator/dist/
/tools/bgs-translator/*.egg-info/

# Universal Python dev-artifact excludes — apply at any depth, including inside
# the materialized plugins/bgs-modding-superpowers/tools/bgs-translator/ tree.
# These caches are produced by pytest / mypy / ruff and must not ship to
# end-user vendor clones.
**/__pycache__/
**/.mypy_cache/
**/.pytest_cache/
**/.ruff_cache/
**/*.egg-info/

# Mirror the bgs-translator source-side build artifact excludes inside the
# materialized plugin tree, for the same reason.
/plugins/bgs-modding-superpowers/tools/bgs-translator/build/
/plugins/bgs-modding-superpowers/tools/bgs-translator/dist/
