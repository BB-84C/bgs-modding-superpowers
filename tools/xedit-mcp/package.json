{
  "name": "xedit-mcp",
  "version": "0.1.0",
  "description": "Harness MCP server for the forked xEdit automation daemon.",
  "type": "module",
  "private": true,
  "bin": {
    "xedit-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "test": "vitest run --exclude tests/integration",
    "test:watch": "vitest",
    "test:integration": "cross-env XEDIT_MCP_INTEGRATION=1 vitest run tests/integration",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "package.json",
    "tsconfig.json"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
